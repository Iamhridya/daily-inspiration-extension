{
  "manifest_version": 3,
  "name": "Daily Inspiration",
  "version": "1.0.0",
  "description": "Beautiful motivational quotes and inspiration.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.quotable.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}